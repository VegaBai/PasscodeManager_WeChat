<view class="page">
  <view class="topbar">
    <view class="topbar-title">
      <view class="title">羽毛球Drop-in排队管理</view>
      <view class="subtitle" wx:if="{{currentGroup && currentGroup.openGId}}">
        <open-data type="groupName" open-gid="{{currentGroup.openGId}}"></open-data>
      </view>
      <view class="subtitle" wx:elif="{{currentGroup}}">{{currentGroup.displayName || currentGroup.name}}</view>
      <view class="subtitle" wx:else>选择或创建一个群</view>
    </view>
    <view class="primary-button switch-group-button" bindtap="openSwitchGroupDialog">切换微信群</view>
  </view>

  <view class="section group-section">
    <view class="group-row" wx:if="{{groups.length}}">
      <view class="group-label">球群</view>
      <view class="group-name" wx:if="{{currentGroup && currentGroup.openGId}}">
        <open-data type="groupName" open-gid="{{currentGroup.openGId}}"></open-data>
      </view>
      <view class="group-name" wx:else>{{currentGroup ? currentGroup.displayName : '选择球群'}}</view>
      <view class="invite-code" wx:if="{{currentGroup}}">{{currentGroup.openGIdShort || currentGroup.sourceText || '微信群'}}</view>
    </view>
  </view>

  <view class="group-court-divider"></view>

  <view class="refresh-row {{loading ? 'is-loading' : ''}}" bindtap="refreshDashboard">
    <view class="refresh-button">{{loading ? '刷新中' : '刷新'}}</view>
  </view>

  <view wx:if="{{currentGroup}}">
    <view class="section-block">
      <view class="block-title">
        <text>场地</text>
        <text class="block-title-hint">注意手动录入可能与球馆系统有时间误差</text>
      </view>

      <view class="court-stat-item court-stat-playing">
        <view class="court-stat-title">
          <text>正在打 {{courtStats.playingCount}} 个场地</text>
          <text class="court-stat-hint"> 场地号（剩余分钟数）</text>
        </view>
        <view class="court-stat-courts" wx:if="{{courtStats.playingItems.length}}">
          <text class="court-stat-label">场地号：</text>
          <text class="court-chip" wx:for="{{courtStats.playingItems}}" wx:key="key">
            <text>{{item.courtName}}</text><text wx:if="{{item.isHalf}}" class="court-half">半</text><text wx:if="{{item.hasMinutes}}" class="court-time court-time-playing">（{{item.minutes}}）</text><text wx:if="{{index < courtStats.playingItems.length - 1}}" class="court-separator">, </text>
          </text>
        </view>
        <view class="court-stat-empty" wx:else>场地号：无</view>
      </view>

      <view class="court-stat-item">
        <view class="court-stat-title">
          <text>排队中 {{courtStats.queuedCount}} 个场地</text>
          <text class="court-stat-hint"> 场地号（等待分钟数）</text>
        </view>
        <view class="court-stat-courts" wx:if="{{courtStats.queuedItems.length}}">
          <text class="court-stat-label">场地号：</text>
          <text class="court-chip" wx:for="{{courtStats.queuedItems}}" wx:key="key">
            <text>{{item.courtName}}</text><text wx:if="{{item.isHalf}}" class="court-half">半</text><text wx:if="{{item.hasMinutes}}" class="court-time court-time-queued">（{{item.minutes}}）</text><text wx:if="{{index < courtStats.queuedItems.length - 1}}" class="court-separator">, </text>
          </text>
        </view>
        <view class="court-stat-empty" wx:else>场地号：无</view>
      </view>

      <view class="queue-actions">
        <view class="queue-toggle" bindtap="toggleQueuePanel">{{queueOpen ? '收起排队' : '添加排队'}}</view>
      </view>

      <view class="section queue-panel" wx:if="{{queueOpen}}">
        <view class="section-title">排队</view>
        <view class="queue-warning">本系统无法自动获取场地信息，请确保输入准确</view>
        <view class="inline-form">
          <view class="field-label">场地号：</view>
          <input class="input court-input" placeholder-class="queue-input-placeholder" placeholder="场地编号" value="{{courtName}}" bindinput="onCourtNameInput" />
          <input wx:if="{{!courtPreview.hasTrackedCourt}}" class="input remaining-input" type="number" placeholder-class="queue-input-placeholder" placeholder="当前剩余分钟" value="{{courtRemainingMinutes}}" bindinput="onCourtRemainingInput" />
          <input wx:if="{{!courtPreview.hasTrackedCourt}}" class="input ahead-input" type="number" placeholder-class="queue-input-placeholder" placeholder="前方排队组数" value="{{courtAheadGroups}}" bindinput="onCourtAheadGroupsInput" />
          <view class="queue-info">
            <view>第 {{courtPreview.nextGroupNo}} 组</view>
            <view wx:if="{{!courtPreview.hasTrackedCourt}}">当前剩余 {{courtPreview.remainingMinutes}} 分钟</view>
            <view>预计等待 {{courtPreview.waitMinutes}} 分钟</view>
          </view>
        </view>

        <view class="half-group-panel" wx:if="{{halfGroupOptions.length}}">
          <view class="half-group-title">补全半场</view>
          <radio-group bindchange="onHalfGroupChange">
            <label class="half-group-option">
              <radio value="__new__" checked="{{!targetQueueEntryId}}" />
              <text>新排一组</text>
            </label>
            <label class="half-group-option" wx:for="{{halfGroupOptions}}" wx:key="id">
              <radio value="{{item.id}}" checked="{{targetQueueEntryId === item.id}}" />
              <text>{{item.label}} · {{item.statusText}}</text>
            </label>
          </radio-group>
        </view>

        <checkbox-group bindchange="onQueueSelect">
          <view class="check-list">
            <label class="check-row" wx:for="{{idleCredentials}}" wx:key="_id">
              <checkbox value="{{item._id}}" checked="{{item.selected}}" />
              <view class="check-account">
                <view class="check-name">{{item.username}}</view>
                <view class="check-pass">{{item.password}}</view>
              </view>
            </label>
          </view>
        </checkbox-group>

        <view class="queue-footer">
          <view class="selected-count">已选 {{selectedIds.length}} 个</view>
          <button class="primary-button" bindtap="addQueueEntry" loading="{{savingQueue}}">确认排队</button>
        </view>
      </view>
    </view>

    <view class="section-block">
      <view class="block-title">
        <text>账号</text>
        <text class="block-title-hint">所有账号信息将在美国西部 PT 时间晚上12点清空</text>
      </view>

      <view class="stats">
        <view class="stat-item">
          <view class="stat-value">{{stats.total}}</view>
          <view class="stat-label">全部</view>
        </view>
        <view class="stat-item">
          <view class="stat-value">{{stats.idle}}</view>
          <view class="stat-label">空闲</view>
        </view>
        <view class="stat-item">
          <view class="stat-value">{{stats.playing}}</view>
          <view class="stat-label">正在打</view>
        </view>
        <view class="stat-item">
          <view class="stat-value">{{stats.queued}}</view>
          <view class="stat-label">排队</view>
        </view>
      </view>

      <view class="section add-account-section">
        <view class="section-title">添加账号</view>
        <view class="inline-form add-account-form">
          <input class="input" maxlength="32" placeholder="用户名" value="{{username}}" bindinput="onUsernameInput" />
          <input class="input" maxlength="32" placeholder="密码" value="{{password}}" bindinput="onPasswordInput" />
          <button class="primary-button" bindtap="addCredential">确定</button>
        </view>
      </view>

      <view class="section list-section">
        <view class="section-title">账号池</view>
        <view class="empty" wx:if="{{!sortedCredentials.length}}">暂无账号</view>

        <view class="credential-card" wx:for="{{sortedCredentials}}" wx:key="_id">
          <view class="credential-head">
            <view class="credential-line">
              <view class="credential-name">{{item.username}}</view>
              <view wx:if="{{item.canDelete}}" class="delete-icon-button" data-id="{{item._id}}" bindtap="deleteCredential">×</view>
              <view class="credential-pass">{{item.password}}</view>
            </view>
            <view class="status-pill status-{{item.status}}">{{item.statusText}}</view>
            <view wx:if="{{item.canCancelQueue}}" class="cancel-icon-button danger" data-entry-id="{{item.currentQueueEntryId}}" data-credential-id="{{item._id}}" bindtap="cancelQueueEntry">取消</view>
          </view>

          <view class="meta-row" wx:if="{{item.courtName}}">
            <text>场地号：{{item.courtName}}</text>
            <text wx:if="{{item.hasGroupNo}}">第 {{item.groupNo}} 组</text>
            <text>{{item.timeText}}</text>
          </view>
          <view class="meta-row">
            <text>{{item.ownerText}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="switch-group-overlay" wx:if="{{switchGroupDialogOpen}}">
    <view class="switch-group-dialog">
      <view class="switch-group-title">切换微信群</view>
      <view class="switch-group-message">转发到微信群后，从群里的链接打开，即可查看群排队</view>
      <view class="switch-group-actions">
        <view class="switch-group-cancel" bindtap="closeSwitchGroupDialog">取消</view>
        <button class="primary-button switch-group-share" open-type="share" bindtap="closeSwitchGroupDialog">转发到微信群</button>
      </view>
    </view>
  </view>

  <view class="cancel-overlay" wx:if="{{cancelDialogOpen}}">
    <view class="cancel-dialog">
      <view class="cancel-dialog-title">选择要取消的账号</view>
      <view class="cancel-dialog-subtitle">必须选择 2 个或 4 个</view>
      <checkbox-group bindchange="onCancelSelect">
        <label class="cancel-option" wx:for="{{cancelOptions}}" wx:key="id">
          <checkbox value="{{item.id}}" />
          <view class="cancel-option-text">
            <text class="cancel-option-name">{{item.username}}</text>
            <text class="cancel-option-pass">{{item.password}}</text>
          </view>
        </label>
      </checkbox-group>
      <view class="cancel-dialog-actions">
        <view class="cancel-secondary" bindtap="closeCancelDialog">返回</view>
        <view class="cancel-primary {{cancelCanConfirm ? '' : 'is-disabled'}}" bindtap="confirmCancelSelection">确认取消</view>
      </view>
    </view>
  </view>
</view>
