.page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.topbar-title {
  min-width: 0;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.2;
  word-break: break-word;
}

.subtitle {
  color: #65727f;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.icon-button,
.primary-button,
.secondary-button,
.queue-toggle {
  height: 72rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  line-height: 72rpx;
  padding: 0 24rpx;
}

.icon-button {
  background: #ffffff;
  color: #334155;
  border: 1rpx solid #d8dee4;
}

.section {
  background: #ffffff;
  border: 1rpx solid #e1e5e8;
  border-radius: 8rpx;
  padding: 22rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 18rpx;
}

.section-block {
  margin-bottom: 24rpx;
}

.block-title {
  color: #1f2933;
  font-size: 36rpx;
  font-weight: 700;
  margin: 28rpx 0 16rpx;
}

.block-title-hint {
  color: #7b8794;
  font-size: 20rpx;
  font-weight: 500;
  margin-left: 24rpx;
}

.group-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.group-label {
  flex: none;
  color: #1f2933;
  font-size: 28rpx;
  font-weight: 700;
}

.group-name {
  flex: 1;
  min-width: 0;
  height: 68rpx;
  line-height: 68rpx;
  padding: 0 20rpx;
  border: 1rpx solid #d8dee4;
  border-radius: 8rpx;
  background: #fbfbfa;
  font-size: 28rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.invite-code {
  flex: none;
  max-width: 220rpx;
  color: #65727f;
  font-size: 22rpx;
  word-break: break-all;
  text-align: right;
}

.wechat-group-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.group-share-button {
  flex: none;
}

.group-hint {
  flex: 1;
  color: #65727f;
  font-size: 24rpx;
  line-height: 1.4;
}

.inline-form {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 12rpx;
}

.field-label {
  flex: none;
  color: #334155;
  font-size: 28rpx;
  font-weight: 600;
}

.input {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  border: 1rpx solid #d8dee4;
  border-radius: 8rpx;
  padding: 0 20rpx;
  background: #fbfbfa;
  font-size: 28rpx;
}

.court-input {
  max-width: 190rpx;
}

.remaining-input {
  max-width: 230rpx;
}

.ahead-input {
  max-width: 230rpx;
}

.queue-input-placeholder {
  font-size: 22rpx;
}

.primary-button {
  background: #176b5b;
  color: #ffffff;
}

.switch-group-button {
  flex: none;
  padding: 0 20rpx;
  font-size: 26rpx;
}

.group-section {
  margin-bottom: 0;
}

.group-court-divider {
  height: 0;
  margin: 25rpx 0;
  border-top: 1rpx solid #e1e5e8;
}

.refresh-row {
  width: 100%;
  height: 72rpx;
  border: 1rpx solid #d8dee4;
  border-radius: 8rpx;
  background: #ffffff;
  margin-bottom: 16rpx;
  box-sizing: border-box;
}

.refresh-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  color: #334155;
  font-size: 28rpx;
  line-height: 72rpx;
  box-sizing: border-box;
}

.refresh-row.is-loading {
  opacity: 0.72;
}

.secondary-button {
  background: #e8f1ee;
  color: #176b5b;
}

.court-stats {
  display: grid;
  grid-template-columns: 1fr;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.court-stat-item {
  background: #ffffff;
  border: 1rpx solid #e1e5e8;
  border-radius: 8rpx;
  padding: 16rpx;
}

.court-stat-playing {
  background: #dff2e6;
  padding: 22rpx;
}

.court-stat-playing .court-stat-title {
  font-size: 30rpx;
}

.court-stat-playing .court-stat-hint {
  font-size: 22rpx;
}

.court-stat-playing .court-stat-courts,
.court-stat-playing .court-stat-empty,
.court-stat-playing .court-stat-label {
  font-size: 26rpx;
}

.court-stat-playing .court-chip,
.court-stat-playing .court-separator {
  font-size: 38rpx;
}

.court-stat-playing .court-half,
.court-stat-playing .court-time {
  font-size: 24rpx;
}

.court-stat-item + .court-stat-item {
  margin-top: 15rpx;
}

.court-stat-title {
  color: #263238;
  font-size: 26rpx;
  font-weight: 700;
}

.court-stat-hint {
  color: #7b8794;
  font-size: 20rpx;
  font-weight: 500;
  margin-left: 16rpx;
}

.court-stat-courts {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8rpx;
  color: #65727f;
  font-size: 24rpx;
  line-height: 1.4;
  margin-top: 8rpx;
  word-break: break-all;
}

.court-stat-empty {
  color: #65727f;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.court-stat-label {
  color: #65727f;
  font-size: 24rpx;
}

.court-chip {
  color: #1f2933;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.2;
}

.court-half {
  font-size: 22rpx;
  font-weight: 600;
  margin-left: 2rpx;
}

.court-time {
  font-size: 20rpx;
  font-weight: 600;
  margin-left: 2rpx;
}

.court-time-playing {
  color: #7b8794;
}

.court-time-queued {
  color: #7b8794;
}

.court-separator {
  font-size: 32rpx;
  font-weight: 700;
}

.stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-bottom: 15rpx;
}

.stat-item {
  background: #ffffff;
  border: 1rpx solid #e1e5e8;
  border-radius: 8rpx;
  padding: 18rpx 8rpx;
  text-align: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
}

.stat-label {
  color: #65727f;
  font-size: 22rpx;
  margin-top: 4rpx;
}

.queue-actions {
  width: 100%;
  margin: 15rpx 0 20rpx;
  background: #ffffff;
  border: 1rpx solid #e1e5e8;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.queue-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 72rpx;
  border-radius: 8rpx;
  box-sizing: border-box;
  background: #176b5b;
  color: #ffffff;
  font-size: 28rpx;
}

.add-account-form > .input,
.add-account-form > .primary-button {
  flex: 1;
  width: 0;
  min-width: 0;
}

.add-account-section {
  margin-bottom: 15rpx;
}

.switch-group-overlay {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 19;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 36rpx;
  background: rgba(31, 41, 51, 0.35);
  box-sizing: border-box;
}

.switch-group-dialog {
  width: 100%;
  max-width: 620rpx;
  padding: 28rpx;
  border-radius: 8rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.switch-group-title {
  color: #1f2933;
  font-size: 32rpx;
  font-weight: 700;
}

.switch-group-message {
  color: #52606d;
  font-size: 28rpx;
  line-height: 1.5;
  margin-top: 14rpx;
}

.switch-group-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 28rpx;
}

.switch-group-cancel,
.switch-group-share {
  flex: none;
  min-width: 160rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  text-align: center;
}

.switch-group-cancel {
  background: #f1f3f5;
  color: #334155;
}

.switch-group-share {
  margin: 0;
  padding: 0 20rpx;
}

.queue-info {
  flex: 1;
  color: #52606d;
  font-size: 24rpx;
  line-height: 1.6;
}

.queue-warning {
  color: #b42318;
  font-size: 22rpx;
  line-height: 1.4;
  margin-top: -6rpx;
}

.queue-panel .inline-form {
  align-items: flex-start;
  flex-wrap: wrap;
}

.queue-panel .queue-info {
  flex-basis: 100%;
}

.half-group-panel {
  margin-top: 18rpx;
  padding: 16rpx;
  border-radius: 8rpx;
  background: #fbfbfa;
  border: 1rpx solid #edf0f2;
}

.half-group-title {
  color: #334155;
  font-size: 24rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.half-group-option {
  display: flex;
  align-items: center;
  min-height: 56rpx;
  color: #52606d;
  font-size: 24rpx;
}

.check-list {
  margin-top: 18rpx;
  border-top: 1rpx solid #edf0f2;
}

.check-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-height: 88rpx;
  border-bottom: 1rpx solid #edf0f2;
}

.check-account {
  display: flex;
  align-items: center;
  min-width: 0;
}

.check-name,
.check-pass {
  min-width: 0;
  font-size: 28rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.check-pass {
  color: #65727f;
  margin-left: 4em;
}

.queue-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 18rpx;
}

.selected-count {
  color: #52606d;
  font-size: 26rpx;
}

.empty {
  color: #7b8794;
  font-size: 28rpx;
  padding: 32rpx 0;
  text-align: center;
}

.credential-card {
  border-bottom: 1rpx solid #edf0f2;
  padding: 20rpx 0;
}

.credential-card:last-child {
  border-bottom: 0;
  padding-bottom: 0;
}

.credential-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.credential-line {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
  gap: 10rpx;
}

.credential-name {
  flex: none;
  max-width: 44%;
  min-width: 0;
  font-size: 32rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.credential-pass {
  flex: 1;
  min-width: 0;
  margin-left: 24rpx;
  color: #1f2933;
  font-size: 32rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.delete-icon-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex: none;
  width: 32rpx;
  height: 32rpx;
  min-width: 32rpx;
  line-height: 32rpx;
  padding: 0;
  border-radius: 50%;
  background: #f1f3f5;
  color: #b42318;
  font-size: 26rpx;
  text-align: center;
}

.status-pill {
  flex: none;
  min-width: 104rpx;
  height: 44rpx;
  line-height: 44rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  text-align: center;
}

.cancel-icon-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex: none;
  width: auto;
  min-width: 0;
  height: 38rpx;
  line-height: 38rpx;
  padding: 0 8rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  box-sizing: border-box;
}

.status-idle {
  background: #e7f4ec;
  color: #176b5b;
}

.status-playing {
  background: #fff1d6;
  color: #8a4f00;
}

.status-queued {
  background: #e7eef8;
  color: #24527a;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  color: #65727f;
  font-size: 24rpx;
  margin-top: 12rpx;
}

.card-actions {
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
  margin-top: 16rpx;
}

.text-button {
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 18rpx;
  border-radius: 8rpx;
  background: #f1f3f5;
  color: #334155;
  font-size: 24rpx;
}

.danger {
  background: #fdebea;
  color: #b42318;
}

.cancel-overlay {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  background: rgba(31, 41, 51, 0.35);
  padding: 28rpx;
  box-sizing: border-box;
}

.cancel-dialog {
  width: 100%;
  max-height: 78vh;
  overflow: auto;
  background: #ffffff;
  border-radius: 8rpx;
  padding: 24rpx;
  box-sizing: border-box;
}

.cancel-dialog-title {
  color: #1f2933;
  font-size: 32rpx;
  font-weight: 700;
}

.cancel-dialog-subtitle {
  color: #65727f;
  font-size: 24rpx;
  margin-top: 8rpx;
  margin-bottom: 12rpx;
}

.cancel-option {
  display: flex;
  align-items: center;
  min-height: 84rpx;
  border-bottom: 1rpx solid #edf0f2;
}

.cancel-option-text {
  display: flex;
  align-items: center;
  gap: 24rpx;
  min-width: 0;
}

.cancel-option-name,
.cancel-option-pass {
  color: #1f2933;
  font-size: 30rpx;
  font-weight: 700;
}

.cancel-dialog-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 20rpx;
}

.cancel-secondary,
.cancel-primary {
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 24rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.cancel-secondary {
  background: #f1f3f5;
  color: #334155;
}

.cancel-primary {
  background: #b42318;
  color: #ffffff;
}

.cancel-primary.is-disabled {
  background: #d8dee4;
  color: #7b8794;
}
